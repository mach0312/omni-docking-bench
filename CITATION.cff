version: "0.1.0"
date-released: "2026-04-17"
license: Apache-2.0
repository-code: "https://github.com/mach0312/omni-docking-bench"
keywords:
  - "ROS 2"
  - "ros2_control"
  - "Nav2"
  - "MPPI"
  - "DWB"
  - "precision docking"
  - "AMR"
  - "double steering drive"
  - "PGV sensor"
  - "reproducibility"
preferred-citation:
